s',\n 'mom6_output',\n 'seawifs']","content_type":"text/plain"}}},"children":[],"key":"xShGt0TNRZ"}],"key":"Ud7zAi1uXm"}],"key":"wycT5nnNPC"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"ProductRegistry.list_access_methods(\"GLORYS\")","key":"Pezvb7q4uD"},{"type":"outputs","id":"trFy3Lkl3VSJar_lpIMBk","children":[{"type":"output","jupyter_data":{"output_type":"execute_result","execution_count":3,"metadata":{},"data":{"text/plain":{"content":"['get_glorys_data_from_rda',\n 'get_glorys_data_from_cds_api',\n 'get_glorys_data_script_for_cli']","content_type":"text/plain"}}},"children":[],"key":"LCYTGyhrXd"}],"key":"ejG9zHQVD9"}],"key":"ouv5qDWIjQ"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"ProductRegistry.get_product(\"GLORYS\")","key":"jHYnHn9EX1"},{"type":"outputs","id":"Ff9BEq5uc3q8_AMU0dems","children":[{"type":"output","jupyter_data":{"output_type":"execute_result","execution_count":4,"metadata":{},"data":{"text/plain":{"content":"CrocoDash.raw_data_access.datasets.glorys.GLORYS","content_type":"text/plain"}}},"children":[],"key":"hPL4zeAXKz"}],"key":"HE3rXk0DNL"}],"key":"YXkAOM5OUw"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# For example, with what we printed above, we can configure the case to use the GLORYS product and a function from that product as follows:\n\ncase.configure_forcings(date_range = [\"2020-01-01 00:00:00\", \"2020-01-09 00:00:00\"], \n                       product_name = \"GLORYS\", \n                       function_name = \"get_glorys_data_from_cds_api\")","key":"A7nlFUxMBO"},{"type":"outputs","id":"V5ueYDI31x_tn8asXm8sB","children":[],"key":"CzE7vR8SzR"}],"key":"KywPPRWhDO"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Accessing non-forcing raw data","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"p0jbBaajeY"}],"identifier":"accessing-non-forcing-raw-data","label":"Accessing non-forcing raw data","html_id":"accessing-non-forcing-raw-data","implicit":true,"key":"Sxe9nOb1Qq"},{"type":"paragraph","position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"children":[{"type":"text","value":"Apart from accessing forcing products through case.configure_forcings(), we can access products like GEBCO, SEAWIFS, GLOFAS, etc.. through importing the raw data access module, like below.","position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"key":"Ltzh6X1E9x"}],"key":"xSIRSb9gUn"}],"key":"fNnTkyM7Pe"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Import the specific module (which can be found by looking at the API Documentation: https://crocodile-cesm.github.io/CrocoDash/api-docs/CrocoDash.raw_data_access.datasets.html)\nfrom CrocoDash.raw_data_access.datasets import glofas as gl\n\n# Then call the function\ngl.get_processed_global_glofas_script_for_cli(output_folder=\"sample\", output_filename=\"glofas_processed_data.nc\")\n\n\n# OR\nProductRegistry.get_access_function(\"GLOFAS\",\"get_processed_global_glofas_script_for_cli\")(output_folder=\"sample\", output_filename=\"glofas_processed_data.nc\")","key":"w2RMnMdo19"},{"type":"outputs","id":"BD4g_DRPGT89DB5eVtFlM","children":[],"key":"uN1SX7MrDu"}],"key":"z29qMf8Qhj"}],"key":"fXQTG5gxdD"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"Setup Offline or Iterative OBC generation (for Long CESM-MOM6 runs)","url":"/notebooks/crocodash/features/data-handling/too-much-data","group":"Data Products"},"next":{"title":"Add data runoff from GLOFAS or JRA to the Run","url":"/notebooks/crocodash/features/add-rof","group":"Additional Components"}}},"domain":"http://localhost:3000"}