{"version":3,"kind":"Notebook","sha256":"3b1f9e4139b1286567ef4c64b9eaf14b0026b6642224282e37c4c727207938f1","slug":"notebooks.crocodash.features.add-chl","location":"/notebooks/CrocoDash/features/add_chl.ipynb","dependencies":[],"frontmatter":{"title":"Add Chlorophyll Files to the Run","content_includes_title":true,"kernelspec":{"name":"python3","display_name":"CrocoDash","language":"python"},"github":"https://github.com/CROCODILE-CESM/CrocoGallery","numbering":{"title":{"offset":3}},"source_url":"https://github.com/CROCODILE-CESM/CrocoGallery/blob/main/gallery/notebooks/CrocoDash/features/add_chl.ipynb","edit_url":"https://github.com/CROCODILE-CESM/CrocoGallery/edit/main/gallery/notebooks/CrocoDash/features/add_chl.ipynb","exports":[{"format":"ipynb","filename":"add_chl.ipynb","url":"/CrocoGallery/pr-33/build/add_chl-c6b6fb1000781e7523d5cf221443e8ea.ipynb"}]},"widgets":{},"mdast":{"type":"root","children":[{"type":"block","kind":"notebook-code","data":{"tags":["ci-setup"]},"children":[{"type":"code","lang":"python","executable":true,"value":"import pickle\nfrom pathlib import Path\n\nwith open(Path(\"code/ci_case.pkl\"), \"rb\") as f:\n    case = pickle.load(f)\ngrid = case.ocn_grid\ntopo = case.ocn_topo\nvgrid = case.ocn_vgrid\ncaseroot = case.caseroot\ninputdir = case.inputdir","visibility":"show","key":"iOJX8wiycU"},{"type":"outputs","id":"pF_gPLPzKaJWnRe8V7FUg","children":[],"visibility":"show","key":"KKpwqzuA2F"}],"visibility":"show","key":"neqEvSubYS"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":1,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Add Chlorophyll Files to the Run","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"PkmIRNdzm4"}],"identifier":"add-chlorophyll-files-to-the-run","label":"Add Chlorophyll Files to the Run","html_id":"add-chlorophyll-files-to-the-run","implicit":true,"key":"jQ6QBmQzRz"},{"type":"paragraph","position"