onal and resources try calling ESMF directly in the input directory None via\n\n`mpirun -np NUMBER_OF_CPUS ESMF_Regrid -s bathymetry_original.nc -d bathymetry_unfinished.nc -m bilinear --src_var depth --dst_var depth --netcdf4 --src_regional --dst_regional`\n\nFor details see https://xesmf.readthedocs.io/en/latest/large_problems_on_HPC.html\n\nAfterwards, run the 'expt.tidy_bathymetry' method to skip the expensive interpolation step, and finishing metadata, encoding and cleanup.\n\n\n\nRegridding successful! Now calling `tidy_bathymetry` method for some finishing touches...\nTidy bathymetry: Reading in regridded bathymetry to fix up metadata...done. Filling in inland lakes and channels... done.\nsetup bathymetry has finished successfully.\n"},"children":[],"key":"Xcg9JnKnGx"}],"key":"umbc60ELQK"}],"key":"iPbwJ4Tv7K"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"topo.depth.plot()","key":"R7KOYwSGoV"},{"type":"outputs","id":"HXrtTV3lhMdIi9iona7-H","children":[{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"image/png":{"content_type":"image/png","hash":"562f99b64566d7afcc44c6f034ae37c3","path":"/CrocoGallery/pr-35/build/562f99b64566d7afcc44c6f034ae37c3.png"},"text/plain":{"content":"<Figure size 640x480 with 2 Axes>","content_type":"text/plain"}}},"children":[],"key":"xcuFUTfD2M"}],"key":"wCL9AzBqmE"}],"key":"bnmII07YFZ"}],"key":"eQ5YpYJEQQ"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"Basic CrocoDash Tutorial","short_title":"Getting Started","url":"/notebooks/crocodash/tutorials/crocodash-tutorial","group":"CROCOGallery"},"next":{"title":"Use Custom Pre-Generated Grids","url":"/notebooks/crocodash/features/grids/add-grids","group":"Grid Customization"}}},"domain":"http://localhost:3000"}