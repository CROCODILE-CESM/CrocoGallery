{"version":3,"kind":"Article","sha256":"f727cc232b7b59127dcf4111c67374e816df6386dbeaef25247a2d9529d6b703","slug":"notebooks.crocodash.tutorials.cli-workflow","location":"/notebooks/CrocoDash/tutorials/cli_workflow.md","dependencies":[],"frontmatter":{"title":"Running CrocoDash from the CLI","content_includes_title":false,"github":"https://github.com/CROCODILE-CESM/CrocoGallery","numbering":{"title":{"offset":1}},"source_url":"https://github.com/CROCODILE-CESM/CrocoGallery/blob/main/gallery/notebooks/CrocoDash/tutorials/cli_workflow.md","edit_url":"https://github.com/CROCODILE-CESM/CrocoGallery/edit/main/gallery/notebooks/CrocoDash/tutorials/cli_workflow.md","exports":[{"format":"md","filename":"cli_workflow.md","url":"/CrocoGallery/latest/build/cli_workflow-2ec53d1e7b5d0fc9cf3aa7172ca69214.md"}]},"mdast":{"type":"root","children":[{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"CrocoDash cases can be set up entirely from the command line using a YAML config file — no Python scripting required.","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"Faw6QpXKmb"}],"key":"FVnLo9ZUT3"},{"type":"paragraph","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"text","value":"The workflow is three steps:","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"JiA4C5ntRz"}],"key":"YR3gkcCkIG"},{"type":"code","lang":"bash","value":"# 1. Get a starter config\ncrocodash template --output my_case.yaml\n\n# 2. Edit it (fill in paths, domain, compset, etc.)\nvim my_case.yaml\n\n# 3. Create the case\ncrocodash create --config my_case.yaml","position":{"start":{"line":7,"column":1},"end":{"line":16,"column":1}},"key":"xZxz79W1HN"},{"type":"paragraph","position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"children":[{"type":"text","value":"Add ","position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"key":"C3qjLohkcE"},{"type":"inlineCode","value":"--machine derecho","position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"key":"XKWkeY6UB8"},{"type":"text","value":" to ","position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"key":"DqCWL7slyi"},{"type":"inlineCode","value":"template","position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"key":"djwuxh2eEC"},{"type":"text","value":" to pre-fill known dataset paths for Derecho/GLADE:","position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"key":"CVSw6seKpf"}],"key":"JCRTZ5iFNW"},{"type":"code","lang":"bash","value":"crocodash template --output my_case.yaml --machine derecho","position":{"start":{"line":20,"column":1},"end":{"line":22,"column":1}},"key":"EF5v6t5EaU"},{"type":"thematicBreak","position":{"start":{"line":24,"column":1},"end":{"line":24,"column":1}},"key":"NRGmI9pB20"},{"type":"heading","depth":2,"position":{"start":{"line":26,"column":1},"end":{"line":26,"column":1}},"children":[{"type":"text","value":"Starter config","position":{"start":{"line":26,"column":1},"end":{"line":26,"column":1}},"key":"R5S29BrgiW"}],"identifier":"starter-config","label":"Starter config","html_id":"starter-config","implicit":true,"key":"d1lRw8GLr2"},{"type":"paragraph","position":{"start":{"line":28,"column":1},"end":{"line":28,"column":1}},"children":[{"type":"text","value":"The template gives you a fully annotated YAML with all available options:","position":{"start":{"line":28,"column":1},"end":{"line":28,"column":1}},"key":"Mmxuf0av98"}],"key":"MiAR9WKwpT"},{"type":"include","file":"starter_case.yaml","literal":true,"children":[{"type":"code","value":"# CrocoDash starter case config\n# Edit this file, then run: crocodash create --config <this_file>\n# Tip: run `crocodash dump --caseroot PATH` on an existing case to generate a config.\n\n# ── Grid ─────────────────────────────────────────────────────────────────────\n# Option A (recommended for new cases): define the domain by extent and resolution\ngrid:\n  lenx: 3.0          # domain width  (degrees longitude)\n  leny: 3.0          # domain height (degrees latitude)\n  xstart: 278.0      # western edge longitude\n  ystart: 7.0        # southern edge latitude\n  resolution: 0.1    # grid resolution in degrees  (or use nx/ny instead)\n  name: my_case\n\n# Option B: load an existing supergrid file\n# grid:\n#   supergrid_path: /path/to/ocean_hgrid.nc\n#   name: my_case\n\n# ── Bathymetry ────────────────────────────────────────────────────────────────\ntopo:\n  min_depth: 9.5\n  source:\n    type: flat         # flat | dataset | from_file\n    depth: 5000.0      # constant ocean depth in metres  (flat only)\n\n    # type: dataset    # interpolate from a bathymetry file (e.g. GEBCO)\n    # bathymetry_path: <GEBCO>\n    # longitude_coordinate_name: lon   # default\n    # latitude_coordinate_name: lat    # default\n    # vertical_coordinate_name: elevation  # default\n\n    # type: from_file  # load a pre-computed topo file\n    # topo_file_path: /path/to/ocean_topog.nc\n\n# ── Vertical grid ─────────────────────────────────────────────────────────────\nvgrid:\n  type: uniform      # uniform | hyperbolic | from_file\n  nk: 75\n  # depth omitted → uses topo.max_depth automatically\n\n  # type: hyperbolic  # surface-intensified layers\n  # nk: 75\n  # ratio: 10.0       # ratio of thickest to thinnest layer\n\n  # type: from_file\n  # filename: /path/to/vgrid.nc\n\n# ── CESM case ─────────────────────────────────────────────────────────────────\ncase:\n  cesmroot: <CESM>\n  caseroot: <casedir>/my_case\n  inputdir: <inputdir>/my_case\n  compset: \"1850_DATM%JRA_SLND_SICE_MOM6%REGIONAL_SROF_SGLC_SWAV\"\n  machine: derecho\n  project: YOUR_PROJECT    # HPC allocation (e.g. ncgd0011)\n  atm_grid_name: TL319     # atmospheric grid; TL319 ≈ 0.5° resolution\n\n  # optional CESM tuning:\n  # rof_grid_name: null\n  # ninst: 1\n  # ntasks_ocn: null\n  # job_queue: main\n  # job_wallclock_time: \"01:00:00\"\n\n# ── Forcings ───────────────────────────────────────────────────────\nforcings:\n  date_range: [\"2020-01-01 00:00:00\", \"2020-12-31 00:00:00\"]\n  boundaries: [north, south, east, west]\n  product_name: GLORYS\n  function_name: get_glorys_data_from_rda\n\n  # Tidal forcing (optional):\n  # tidal_constituents: [M2, S2, K1, O1]\n  # tpxo_elevation_filepath: <TPXO_H>\n  # tpxo_velocity_filepath: <TPXO_U>\n\n  # BGC initial conditions (optional):\n  # marbl_ic_filepath: <MARBL_IC>\n","lang":"yaml","filename":"starter_case.yaml","key":"fLUUMXSFSo"}],"key":"ntJZUPxR6F"},{"type":"thematicBreak","position":{"start":{"line":34,"column":1},"end":{"line":34,"column":1}},"key":"cUVloMAZoz"},{"type":"heading","depth":2,"position":{"start":{"line":36,"column":1},"end":{"line":36,"column":1}},"children":[{"type":"text","value":"Round-tripping an existing case","position":{"start":{"line":36,"column":1},"end":{"line":36,"column":1}},"key":"hHndn4YkaO"}],"identifier":"round-tripping-an-existing-case","label":"Round-tripping an existing case","html_id":"round-tripping-an-existing-case","implicit":true,"key":"brzMn2igBZ"},{"type":"paragraph","position":{"start":{"line":38,"column":1},"end":{"line":38,"column":1}},"children":[{"type":"text","value":"If you already have a CrocoDash case and want to reproduce or modify it, ","position":{"start":{"line":38,"column":1},"end":{"line":38,"column":1}},"key":"RbVj4C3cq5"},{"type":"inlineCode","value":"dump","position":{"start":{"line":38,"column":1},"end":{"line":38,"column":1}},"key":"vyqJrzrw19"},{"type":"text","value":" reconstructs the YAML from the case’s state files:","position":{"start":{"line":38,"column":1},"end":{"line":38,"column":1}},"key":"coCYPJRUTl"}],"key":"dKXZaGe8qy"},{"type":"code","lang":"bash","value":"crocodash dump --caseroot /path/to/my_case > my_case.yaml","position":{"start":{"line":40,"column":1},"end":{"line":42,"column":1}},"key":"rYLDXsfV