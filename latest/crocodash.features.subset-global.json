":"python","executable":true,"value":"from CrocoDash.grid import Grid\n\ngrid = Grid.subgrid_from_supergrid(\n    path = \"<HGRID_TRIMMED>\",  # supergrid\n    llc = (16.0, 192.0),  # (l)ower (l)eft (c)orner coords\n    urc = (27.0, 209.0),  # (u)pper (r)ight (c)orner coords\n    name = \"hawaii_2\"\n)","key":"Cgb256PgBC"},{"type":"outputs","id":"lKuRlaWF1aIrkwDjJwwaY","children":[],"key":"ukX0oVGcsw"}],"key":"jjNl04yDan"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Step 1.2: Topography","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"rFEx8CKFAo"}],"identifier":"step-1-2-topography","label":"Step 1.2: Topography","html_id":"step-1-2-topography","implicit":true,"key":"PtyL4qrIVp"}],"key":"zU6MASGNqw"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"from CrocoDash.topo import Topo\n\ntopo = Topo(\n    grid = grid,\n    min_depth = 9.5,\n)","key":"CKhy2yBkxh"},{"type":"outputs","id":"QbVLz4uU8wqo2A5C55Nyy","children":[],"key":"blp7PVXDpz"}],"key":"ced5YCs3PV"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"bathymetry_path='<GEBCO_LOWRES>'\n\ntopo.set_from_dataset(\n    bathymetry_path = bathymetry_path,\n    longitude_coordinate_name=\"lon\",\n    latitude_coordinate_name=\"lat\",\n    vertical_coordinate_name=\"elevation\"\n)","key":"jQ2LNlx5Pl"},{"type":"outputs","id":"XwbBDFUKbtIFAeP_fJwJN","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"Begin regridding bathymetry...\n\nOriginal bathymetry size: 6.26 Mb\nRegridded size: 0.70 Mb\nAutomatic regridding may fail if your domain is too big! If this process hangs or crashes,open a terminal with appropriate computational and resources try calling ESMF directly in the input directory None via\n\n`mpirun -np NUMBER_OF_CPUS ESMF_Regrid -s bathymetry_original.nc -d bathymetry_unfinished.nc -m bilinear --src_var depth --dst_var depth --netcdf4 --src_regional --dst_regional`\n\nFor details see https://xesmf.readthedocs.io/en/latest/large_problems_on_HPC.html\n\nAfterwards, run the 'expt.tidy_bathymetry' method to skip the expensive interpolation step, and finishing metadata, encoding and cleanup.\n\n\n\nRegridding successful! Now calling `tidy_bathymetry` method for some finishing touches...\nTidy bathymetry: Reading in regridded bathymetry to fix up metadata...done. Filling in inland lakes and channels... done.\nsetup bathymetry has finished successfully.\n"},"children":[],"key":"jcVpdoV4Xo"}],"key":"NM5IjERQ3r"}],"key":"GxMsEXd8XN"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"topo.depth.plot()","key":"ZTmq26quDV"},{"type":"outputs","id":"O87-zqRlKwPskXZbfE7SQ","children":[{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"image/png":{"content_type":"image/png","hash":"562f99b64566d7afcc44c6f034ae37c3","path":"/CrocoGallery/latest/build/562f99b64566d7afcc44c6f034ae37c3.png"},"text/plain":{"content":"<Figure size 640x480 with 2 Axes>","content_type":"text/plain"}}},"children":[],"key":"lZ2yOImuTf"}],"key":"ChgUsXh0xs"}],"key":"cbGYnM9iP5"}],"key":"svV5pQbcFV"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"Running CrocoDash from the CLI","short_title":"CLI Workflow","url":"/crocodash/tutorials/cli-workflow","group":"CROCOGallery"},"next":{"title":"Use Custom Pre-Generated Grids","url":"/crocodash/features/add-grids","group":"Grid Customization"}}},"domain":"http://localhost:3000"}